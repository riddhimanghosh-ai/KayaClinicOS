{
  "name": "kaya-os",
  "version": "0.3.0",
  "private": true,
  "description": "KayaOS v3 — AI clinic operating system for Kaya Skin Clinic (Next.js prototype).",
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "npm run seed",
